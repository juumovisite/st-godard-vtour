<krpano version="1.23" title="Virtual Tour" onstart="delayedcall(0.3, hide_ui());">

	<include url="skin/vtourskin.xml" />

	<events name="hide_on_scene" onscenechange="delayedcall(0.3, hide_ui());" keep="true" />

	<action name="hide_ui">
		set(layer[skin_control_bar].visible, false);
		set(layer[skin_control_bar].y, 9999);
		set(layer[skin_control_bar_bg].visible, false);
		set(layer[skin_control_bar_buttons].visible, false);
		set(layer[skin_splitter_bottom].visible, false);
		set(layer[skin_splitter_bottom].y, 9999);
		set(layer[skin_scroll_window].visible, false);
		set(layer[skin_scroll_window].y, 9999);
		set(layer[skin_scroll_layer].visible, false);
		set(layer[skin_btn_prev].visible, false);
		set(layer[skin_btn_next].visible, false);
		set(layer[skin_btn_thumbs].visible, false);
		set(layer[skin_btn_map].visible, false);
		set(layer[skin_btn_navi].visible, false);
		set(layer[skin_btn_gyro].visible, false);
		set(layer[skin_btn_vr].visible, false);
		set(layer[skin_btn_fs].visible, false);
		set(layer[skin_btn_hide].visible, false);
		set(layer[skin_btn_show].visible, false);
		set(layer[skin_btn_show].y, 9999);
		set(layer[skin_title].visible, false);
		set(layer[skin_title].y, -9999);
	</action>

	<!-- Custom hotspot styles - arrow navigation with tooltip -->
	<style name="hotspot_nav" url="skin/hotspot_arrow.png" edge="center" distorted="true"
	       linkedscene="" linkedscene_lookat="" linkedscene_hoffset="0" use3dtransition="false"
	       onclick="skin_hotspotstyle_click();"
	       depth="1000" scale="0.22"
	       onloaded.addevent="hotspot_arrow_setup(); skin_hotspotstyle_setup();"
	       onover.addevent="tween(scale,0.35,0.3,easeOutBack);"
	       onout.addevent="tween(scale,0.22,0.3,easeOutQuad);"
	       />

	<action name="hotspot_arrow_setup" scope="local">
		if(isvalue(caller.linkedscene) AND caller.linkedscene != 'scene_taginfo',
			copy(caller.tooltip, scene[get(caller.linkedscene)].title);
		);
	</action>

	<style name="hotspot_info" url="skin/hotspot_info.svg" edge="center" distorted="true"
	       linkedscene="" linkedscene_lookat="" linkedscene_hoffset="0" use3dtransition="false"
	       onclick="skin_hotspotstyle_click();"
	       depth="1000" scale="0.55"
	       onover.addevent="tween(scale,0.65);"
	       onout.addevent="tween(scale,0.55);"
	       onloaded.addevent="skin_hotspotstyle_setup();"
	       />

	<skin_settings maps="false"
	               gyro="false"
	               webvr="false"
	               autotour="false"
	               littleplanetintro="false"
	               followmousecontrol="true"
	               title="false"
	               thumbs="false"
	               thumbs_opened="false"
	               tooltips_buttons="false"
	               tooltips_thumbs="false"
	               tooltips_hotspots="true"
	               tooltips_mapspots="false"
	               deeplinking="false"
	               loadscene_flags="MERGE"
	               loadscene_blend="OPENBLEND(0.5, 0.0, 0.75, 0.05, linear)"
	               loadscene_blend_prev="SLIDEBLEND(0.5, 180, 0.75, linear)"
	               loadscene_blend_next="SLIDEBLEND(0.5,   0, 0.75, linear)"
	               loadingtext=""
	               layout_width="0"
	               controlbar_width="0"
	               controlbar_height="0"
	               controlbar_offset="-9999"
	               controlbar_offset_closed="-9999"
	               />
	

	
